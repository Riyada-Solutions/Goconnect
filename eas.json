{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "expo prebuild --clean"
    }
  },
  "submit": {
