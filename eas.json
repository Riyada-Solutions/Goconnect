{
  "cli": {
    "version": ">= 14.0.0",
    "requireCommit": false,
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_DATA": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://nurse-app.careconnectksa.com/api",
        "EXPO_PUBLIC_SIGNATURE_API_BASE_URL": "https://staging.careconnectksa.com/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_DATA": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://nurse-app.careconnectksa.com/api",
        "EXPO_PUBLIC_SIGNATURE_API_BASE_URL": "https://staging.careconnectksa.com/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_DATA": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://nurse-app.careconnectksa.com/api",
        "EXPO_PUBLIC_SIGNATURE_API_BASE_URL": "https://nurse-app.careconnectksa.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "Ahmedsayed.cs2019@gmail.com",
        "ascAppId": "6761141367",
        "appleTeamId": "N3R8MF955Y"
      }
    }
  }
}
