{
  "expo": {
    "name": "CareConnect KSA",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "careconnectksa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#13A8BD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careconnectksa.nurse",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "CareConnect needs camera access to capture patient documents.",
        "NSPhotoLibraryUsageDescription": "CareConnect needs photo library access to upload patient documents.",
        "NSLocationWhenInUseUsageDescription": "CareConnect needs your location to verify visit check-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#13A8BD"
      },
      "package": "com.careconnectksa.nurse",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
