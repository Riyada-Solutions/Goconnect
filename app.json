{
  "expo": {
    "name": "Goconnect",
    "slug": "CareConnectNurse",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "goconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2DAAAE"
    },
    "ios": {
      "supportsTablet": false,
      "requiresFullScreen": true,
      "displayName": "Goconnect",
      "bundleIdentifier": "com.careconnectksa.nurse",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Goconnect needs camera access to capture patient documents.",
        "NSPhotoLibraryUsageDescription": "Goconnect needs photo library access to upload patient documents.",
        "NSLocationWhenInUseUsageDescription": "Goconnect needs your location to verify visit check-in.",
        "NSFaceIDUsageDescription": "Goconnect uses Face ID to sign you in securely.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2DAAAE"
      },
      "package": "com.careconnectksa.nurse",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Goconnect uses Face ID to sign you in securely."
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Goconnect needs photo library access to upload patient documents.",
          "cameraPermission": "Goconnect needs camera access to capture patient documents.",
          "microphonePermission": "Goconnect needs microphone access to record patient videos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Goconnect needs your location to verify visit check-in."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2DAAAE",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "58b171f5-5148-4ba1-933a-59746d4314c3"
      },
      "router": {
        "origin": "https://replit.com/"
      }
    }
  }
}
