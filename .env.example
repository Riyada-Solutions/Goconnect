# Copy to `.env` and fill in. EXPO_PUBLIC_* vars are inlined into the app bundle.

# Set to "false" to hit live APIs; anything else uses mock data.
EXPO_PUBLIC_USE_MOCK_DATA=false

# Main backend API base URL (everything except signature/image uploads).
EXPO_PUBLIC_API_BASE_URL=https://nurse-app.careconnectksa.com/api

# Shared signature / image upload endpoint host. Lives on a different domain
# than the main API. The signature_repository POSTs to `${this}/signatures/upload`.
EXPO_PUBLIC_SIGNATURE_API_BASE_URL=https://staging.careconnectksa.com/api
